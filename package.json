{
	"name": "directus-extension-milkdown-editor",
	"description": "Provide a WYSIWYG markdown editing experience in Directus using Milkdown (Crepe) with direct image upload support.",
	"icon": "edit_document",
	"version": "1.0.1",
	"author": "Yakup Sogut <yakup_sogut@hotmail.com>",
	"license": "MIT",
	"keywords": [
		"directus",
		"directus-extension",
		"directus:extension",
		"directus-extension-interface"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/yakupsogut/directus-extension-milkdown-editor.git"
	},
	"type": "module",
	"files": [
		"dist"
	],
	"directus:extension": {
		"type": "interface",
		"path": "dist/index.js",
		"source": "src/index.js",
		"host": "^10.10.0"
	},
	"scripts": {
		"build": "directus-extension build",
		"dev": "directus-extension build -w --no-minify",
		"link": "directus-extension link",
		"validate": "directus-extension validate"
	},
	"devDependencies": {
		"@directus/extensions-sdk": "17.0.9",
		"postcss": "^8.5.6",
		"postcss-cli": "^11.0.1",
		"postcss-import": "^16.1.1",
		"vue": "^3.5.29"
	},
	"dependencies": {
		"@milkdown/crepe": "^7.18.0"
	}
}